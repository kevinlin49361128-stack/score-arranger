  </credit>
  <credit page="1">
    <credit-words default-x="892" default-y="168" font-family="Adobe Garamond Pro Italic" font-size="7.1" halign="left" justify="right" valign="top" xml:space="preserve">Molto tranquillo
come accompagnamente
la melodia sempre marcata
sempre legatissimo</credit-words>
  </credit>
  <credit page="1">
    <credit-words default-x="1076" default-y="170" font-size="7.1" valign="top" xml:space="preserve">Very tranquil
as an accompaniment
the melody should always be prominent
always most connected</credit-words>
  </credit>
  <credit page="2">
    <credit-words default-x="79" default-y="1822" font-family="Adobe Garamond Pro" valign="top">2</credit-words>
