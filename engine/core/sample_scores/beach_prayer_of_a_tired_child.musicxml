  </credit>
  <credit page="2">
    <credit-words default-x="776" default-y="196" font-size="7.1" valign="top" xml:space="preserve">always
expressively
most sweetly</credit-words>
  </credit>
  <credit page="2">
    <credit-words default-x="683" default-y="195" font-family="Adobe Garamond Pro Italic" font-size="7.1" halign="left" justify="right" valign="top" xml:space="preserve">sempre
espressivo
dolcissimo</credit-words>
  </credit>
